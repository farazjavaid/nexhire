{
  "name": "@nexyre/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "npx nx dev frontend",
    "dev:backend": "npx nx serve backend",
    "dev:all": "npx nx run-many --targets=dev,serve --projects=frontend,backend --parallel",
    "build": "npx nx build frontend",
    "build:backend": "npx nx build backend",
    "build:all": "npx nx run-many --target=build --all",
    "start": "npx nx start frontend",
    "lint": "npx nx run-many --target=lint --all",
    "test": "npx nx run-many --target=test --all",
    "typecheck": "npx nx run-many --target=typecheck --all",
    "db:generate": "npx prisma generate --schema=packages/db/prisma/schema.prisma",
    "db:migrate": "npx prisma migrate dev --schema=packages/db/prisma/schema.prisma",
    "db:migrate:deploy": "npx prisma migrate deploy --schema=packages/db/prisma/schema.prisma",
    "db:studio": "npx prisma studio --schema=packages/db/prisma/schema.prisma"
  },
  "private": true,
  "devDependencies": {
    "@eslint/compat": "^1.1.1",
    "@eslint/eslintrc": "^2.1.1",
    "@eslint/js": "^9.8.0",
